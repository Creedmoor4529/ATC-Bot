# API Keys (only the key for your chosen AI_PROVIDER is required)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# SRS Server
SRS_HOST=127.0.0.1
SRS_PORT=5002

# Tacview Real-Time Telemetry
TACVIEW_HOST=127.0.0.1
TACVIEW_PORT=42674
TACVIEW_PASSWORD=

# Piper TTS
PIPER_EXE=piper/piper.exe
# Voice is set in config.lua (PIPER_VOICE). Override with full path here if needed.
# PIPER_VOICE=piper/voices/en_US-amy-medium.onnx

# DCS export UDP port (must match BOT_PORT in dcs_atc_export.lua)
DCS_EXPORT_PORT=15099

# Logging level — DEBUG, INFO, WARNING, or ERROR (default: DEBUG)
# Set to INFO to reduce console/log noise
LOG_LEVEL=DEBUG


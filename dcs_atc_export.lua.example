--[[
  DCS ATC Bot — weather export hook
  Copy this file to:  %USERPROFILE%\Saved Games\DCS\Scripts\Hooks\dcs_atc_export.lua
  Then edit BOT_HOST and BOT_PORT below.

  BOT_HOST: IP address of the machine running the ATC bot.
    - If the bot is running on the SAME machine as DCS, set to "127.0.0.1"
    - If the bot is running on a DIFFERENT machine (e.g. dedicated server),
      set to that machine's local IP address (e.g. "192.168.1.50")
    - The bot machine must be reachable from the DCS server on BOT_PORT (UDP)

  BOT_PORT: must match DCS_EXPORT_PORT in the bot's .env (default 15099)
--]]

local BOT_HOST      = "127.0.0.1"
local BOT_PORT      = 15099
local CHAT_PORT     = 15100       -- UDP port to receive chat messages from the bot
local INTERVAL_SEC  = 30
local LOG_FILE      = lfs.writedir() .. "Logs\\atc_export.log"  --luacheck: ignore

-- ---------------------------------------------------------------------------

local udp = nil
local chatUdp = nil
local socketOk, socketLib = pcall(require, "socket")
if socketOk then
    udp = socketLib.udp()
    udp:settimeout(0)
    -- Receive socket: bot sends chat messages here
    chatUdp = socketLib.udp()
    chatUdp:settimeout(0)
    chatUdp:setsockname("0.0.0.0", CHAT_PORT)
end

local function log(msg)
    local f = io.open(LOG_FILE, "a")
    if f then
        f:write(os.date("%H:%M:%S") .. " " .. msg .. "\n")
        f:close()
    end
end

local function send(payload)
    if udp then
        udp:sendto(payload, BOT_HOST, BOT_PORT)
    end
    log("SEND: " .. payload)
end


-- Cached mission weather, refreshed on each mission load.
local cachedWeather = nil

local function loadMissionWeather()
    -- DCS.getCurrentMission() returns the full mission table in the hook env.
    -- This gives us the exact weather the mission editor set, not a position query.
    local ok, mission = pcall(DCS.getCurrentMission)  --luacheck: ignore
    if not ok or not mission or not mission.mission then
        log("ERROR: DCS.getCurrentMission() failed: " .. tostring(mission))
        return
    end

    local weather = mission.mission.weather
    if not weather then
        log("ERROR: no weather table in mission")
        return
    end

    -- Ground wind layer
    local gnd = weather.wind and weather.wind.atGround
    local wind_speed_ms = 0
    local wind_dir      = 0
    if gnd then
        wind_speed_ms = (gnd.speed or 0)
        wind_dir      = (gnd.dir   or 0)
        -- DCS mission editor stores wind direction as "blows TO" in degrees.
        -- ATC convention is "wind FROM", so add 180.
        wind_dir = (wind_dir + 180) % 360
    end

    -- Temperature at sea level from weather.season.temperature
    local temp_c = 15
    if weather.season and weather.season.temperature then
        temp_c = weather.season.temperature
    end

    -- QNH from weather.qnh — DCS stores this in mmHg; convert to hPa
    local pressure_hpa = 1013.25
    if weather.qnh then
        pressure_hpa = weather.qnh * 1.33322
    end

    cachedWeather = {
        wind_dir      = wind_dir,
        wind_speed_ms = wind_speed_ms,
        pressure_hpa  = pressure_hpa,
        temp_c        = temp_c,
    }

    log(string.format(
        "Mission weather loaded: wind FROM %.0f at %.1f m/s, QNH %.1f hPa, temp %.1f C",
        wind_dir, wind_speed_ms, pressure_hpa, temp_c
    ))
end

local function queryWeather()
    if not cachedWeather then
        return nil
    end

    local w = cachedWeather
    return string.format(
        '{"wind_dir":%g,"wind_speed_ms":%g,"pressure_hpa":%g,"temp_c":%g}',
        w.wind_dir, w.wind_speed_ms, w.pressure_hpa, w.temp_c
    )
end

local lastSent  = 0
local callbacks = {}

function callbacks.onMissionLoadEnd()
    log("onMissionLoadEnd fired. socket=" .. tostring(socketOk))
    loadMissionWeather()
    send('{"status":"hook_alive"}')
    lastSent = 0
end

function callbacks.onSimulationFrame()
    -- Poll for incoming chat messages from the bot (non-blocking)
    if chatUdp then
        local data = chatUdp:receive()
        if data then
            log("CHAT: " .. data)
            net.send_chat(data, true)  --luacheck: ignore
        end
    end

    local now = os.time()
    if now - lastSent < INTERVAL_SEC then return end
    lastSent = now

    local ok, result = pcall(queryWeather)
    if ok and result and result ~= "" and result ~= "nil" then
        send(result)
    else
        local err = ok and "empty result" or tostring(result)
        send('{"error":"' .. err .. '"}')
    end
end

log("Script loaded. socket=" .. tostring(socketOk) .. " chatPort=" .. tostring(CHAT_PORT))
DCS.setUserCallbacks(callbacks)  --luacheck: ignore
